#include <OneWire.h>
#include <DallasTemperature.h>

#define ONE_WIRE_BUS 32
#define DATA_COUNT 100
#define WINDOW_SIZE 5

OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);

float rawData[DATA_COUNT];
float filteredData[DATA_COUNT];

float getMedian(float window[], int size) {
  for (int i = 0; i < size - 1; i++) {
    for (int j = i + 1; j < size; j++) {
      if (window[j] < window[i]) {
        float temp = window[i];
        window[i] = window[j];
        window[j] = temp;
      }
    }
  }

  return window[size / 2];
}

void applyMedianFilter() {
  int halfWindow = WINDOW_SIZE / 2;

  for (int i = 0; i < DATA_COUNT; i++) {
    float window[WINDOW_SIZE];
    int count = 0;

    for (int j = -halfWindow; j <= halfWindow; j++) {
      int index = i + j;

      if (index >= 0 && index < DATA_COUNT) {
        window[count] = rawData[index];
        count++;
      }
    }

    filteredData[i] = getMedian(window, count);
  }
}

void setup() {
  Serial.begin(115200);
  sensors.begin();

  delay(1000);

  Serial.println("Reading temperature data...");

  for (int i = 0; i < DATA_COUNT; i++) {
    sensors.requestTemperatures();
    rawData[i] = sensors.getTempCByIndex(0);

    Serial.print("Raw[");
    Serial.print(i);
    Serial.print("] = ");
    Serial.print(rawData[i]);
    Serial.println(" °C");

    delay(1000);
  }

  applyMedianFilter();

  Serial.println();
  Serial.println("Index;Raw temperature;Filtered temperature");

  for (int i = 0; i < DATA_COUNT; i++) {
    Serial.print(i);
    Serial.print(";");
    Serial.print(rawData[i]);
    Serial.print(";");
    Serial.println(filteredData[i]);
  }
}

void loop() {
}


