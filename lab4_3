#include <OneWire.h>
#include <DallasTemperature.h>

#define ONE_WIRE_BUS 32
#define DATA_COUNT 100

OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);

float rawData[DATA_COUNT];
float kalmanData[DATA_COUNT];

float err_measure = 1;
float err_estimate = 1;
float q = 0.01;

float current_estimate = 0;
float last_estimate = 0;
float kalman_gain = 0;

float updateKalman(float measurement) {

  kalman_gain = err_estimate / (err_estimate + err_measure);

  current_estimate = last_estimate +
                     kalman_gain * (measurement - last_estimate);

  err_estimate = (1.0 - kalman_gain) * err_estimate +
                 fabs(last_estimate - current_estimate) * q;

  last_estimate = current_estimate;

  return current_estimate;
}

void setup() {

  Serial.begin(115200);

  sensors.begin();

  delay(1000);

  Serial.println("Reading temperature...");

  for (int i = 0; i < DATA_COUNT; i++) {

    sensors.requestTemperatures();

    rawData[i] = sensors.getTempCByIndex(0);

    kalmanData[i] = updateKalman(rawData[i]);

    Serial.print(i);
    Serial.print(";");

    Serial.print(rawData[i]);

    Serial.print(";");

    Serial.println(kalmanData[i]);

    delay(1000);
  }

  Serial.println("DONE");
}

void loop() {
}
